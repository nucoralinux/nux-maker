# ══════════════════════════════════════════════════════════════════
# BUILD ONE
# ══════════════════════════════════════════════════════════════════

build_one() {
    local DEB_FILE="$1"
    local PKG_CLASS="${2:-app}"

    [ -f "$DEB_FILE" ] || {
        echo -e "${R}$(t error): $(t build.not_found): $DEB_FILE${RE}" >&2
        return 1
    }

    local PKG_NAME
    PKG_NAME="$(dpkg-deb -f "$DEB_FILE" Package 2>/dev/null || true)"
    [ -z "$PKG_NAME" ] && { echo -e "${R}$(t build.invalid_deb): $DEB_FILE${RE}" >&2; return 1; }
    [[ "$PKG_NAME" =~ ^[a-z0-9][a-z0-9+.-]*$ ]] || { echo -e "${R}$(t build.invalid_name): $PKG_NAME${RE}" >&2; return 1; }

    local FINAL_CLASS
    FINAL_CLASS="$(determine_class "$PKG_NAME" "$PKG_CLASS")"
    [ -n "$FORCE_CLASS" ] && { FINAL_CLASS="$FORCE_CLASS"; is_tool_package "$PKG_NAME" && FINAL_CLASS="tool"; }

    if already_in_repo "$PKG_NAME"; then
        echo -e "  ${G}[=]${RE} $PKG_NAME $(t build.already) ${DIM}[$FINAL_CLASS]${RE}"
        return 0
    fi

    local PKG_VERSION PKG_ARCH PKG_DESC PKG_MAINTAINER PKG_SECTION PKG_PRIORITY PKG_HOMEPAGE DEB_SIZE
    PKG_VERSION="$(dpkg-deb -f "$DEB_FILE" Version 2>/dev/null || echo "0.0.1")"
    PKG_ARCH="$(dpkg-deb -f "$DEB_FILE" Architecture 2>/dev/null || echo "amd64")"
    PKG_DESC="$(dpkg-deb -f "$DEB_FILE" Description 2>/dev/null | head -1 || echo "")"
    PKG_MAINTAINER="$(dpkg-deb -f "$DEB_FILE" Maintainer 2>/dev/null || echo "Unknown")"
    PKG_SECTION="$(dpkg-deb -f "$DEB_FILE" Section 2>/dev/null || echo "misc")"
    PKG_PRIORITY="$(dpkg-deb -f "$DEB_FILE" Priority 2>/dev/null || echo "optional")"
    PKG_HOMEPAGE="$(dpkg-deb -f "$DEB_FILE" Homepage 2>/dev/null || echo "")"
    DEB_SIZE="$(stat -c%s "$DEB_FILE" 2>/dev/null || echo 0)"

    local CC="$G"; case "$FINAL_CLASS" in base) CC="$Y" ;; tool) CC="$M" ;; esac
    echo -e "${C}════════════════════════════════════════════════════════════${RE}"
    echo -e "  ${G}Paket:${RE} $PKG_NAME  ${G}Ver:${RE} $PKG_VERSION  ${G}Class:${RE} ${CC}${FINAL_CLASS}${RE}"

    local WB="/tmp"; [ -d /dev/shm ] && [ -w /dev/shm ] && WB="/dev/shm"
    local WD; WD="$(mktemp -d "$WB/nux_${PKG_NAME}_XXXXXX")"; register_temp "$WD"
    mkdir -p "$WD/control" "$WD/pkg/files" "$WD/pkg/scripts" "$WD/pkg/control"

    echo -e "  ${Y}[1/5]${RE} $(t build.extracting)"
    dpkg-deb -x "$DEB_FILE" "$WD/pkg/files" 2>/dev/null

    echo -e "  ${Y}[2/5]${RE} $(t build.control)"
    dpkg-deb -e "$DEB_FILE" "$WD/control" 2>/dev/null || true

    echo -e "  ${Y}[3/5]${RE} $(t build.metadata)"
    local DEP PRE REC SUG CON PRO
    DEP="$(dpkg-deb -f "$DEB_FILE" Depends 2>/dev/null || true)"
    PRE="$(dpkg-deb -f "$DEB_FILE" Pre-Depends 2>/dev/null || true)"
    REC="$(dpkg-deb -f "$DEB_FILE" Recommends 2>/dev/null || true)"
    SUG="$(dpkg-deb -f "$DEB_FILE" Suggests 2>/dev/null || true)"
    CON="$(dpkg-deb -f "$DEB_FILE" Conflicts 2>/dev/null || true)"
    PRO="$(dpkg-deb -f "$DEB_FILE" Provides 2>/dev/null || true)"

    local DJ PJ RJ SJ CJ PVJ
    DJ="$(json_list_from_field "$DEP" "depends" "$KEEP_ALL_DEPS")"
    PJ="$(json_list_from_field "$PRE" "pre_depends" "$KEEP_ALL_DEPS")"
    RJ="$(json_list_from_field "$REC" "recommends" "$KEEP_ALL_DEPS")"
    SJ="$(json_list_from_field "$SUG" "suggests" "$KEEP_ALL_DEPS")"
    CJ="$(json_list_from_field "$CON" "conflicts" "$KEEP_ALL_DEPS")"
    PVJ="$(json_list_from_field "$PRO" "provides" "$KEEP_ALL_DEPS")"

    echo -e "  ${Y}[4/5]${RE} $(t build.scripts)"
    create_script_wrapper "preinst"  "$PKG_NAME" "$WD/control/preinst"  "$WD/pkg/scripts"
    create_script_wrapper "postinst" "$PKG_NAME" "$WD/control/postinst" "$WD/pkg/scripts"
    create_script_wrapper "prerm"    "$PKG_NAME" "$WD/control/prerm"    "$WD/pkg/scripts"
    create_script_wrapper "postrm"   "$PKG_NAME" "$WD/control/postrm"   "$WD/pkg/scripts"
    [ -f "$WD/control/conffiles" ] && cp "$WD/control/conffiles" "$WD/pkg/control/conffiles"

    if [ -d "$WD/pkg/files/opt" ]; then
        while IFS= read -r bin; do
            local bn; bn="$(basename "$bin")"
            case "$bn" in *.so|*.so.*|*.a|*.la|*.pc|*.txt|*.json|*.xml|*.conf) continue ;; esac
            local ubp="$WD/pkg/files/usr/bin/$bn"
            if [ ! -e "$ubp" ] && [ ! -L "$ubp" ]; then
                mkdir -p "$WD/pkg/files/usr/bin"
                ln -sf "${bin#$WD/pkg/files}" "$ubp"
            fi
        done < <(find "$WD/pkg/files/opt" -maxdepth 4 -type f -executable 2>/dev/null || true)
    fi

    local IS DH; IS="$(du -sb "$WD/pkg/files" 2>/dev/null | cut -f1 || echo 0)"
    DH="$(sha256sum "$DEB_FILE" | cut -d' ' -f1)"
    local PROT="false"; [ "$FINAL_CLASS" = "tool" ] && PROT="true"
    local ST="deb-import"; case "$FINAL_CLASS" in base) ST="debian-dependency" ;; tool) ST="native" ;; esac

    export META_NAME="$PKG_NAME" META_VERSION="$PKG_VERSION" META_ARCH="$PKG_ARCH"
    export META_DESC="$PKG_DESC" META_MAINTAINER="$PKG_MAINTAINER" META_SECTION="$PKG_SECTION"
    export META_PRIORITY="$PKG_PRIORITY" META_HOMEPAGE="$PKG_HOMEPAGE" META_CLASS="$FINAL_CLASS"
    export META_MANAGED_BY="nux" META_INSTALLED_SIZE="$IS" META_SIZE="$DEB_SIZE"
    export META_SOURCE_SHA256="$DH" META_SOURCE_TYPE="$ST" META_PROTECTED="$PROT"
    export META_MAKER_VERSION="$MAKER_VERSION" META_BUILT_DATE="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
    export META_DEPENDS_JSON="$DJ" META_PRE_DEPENDS_JSON="$PJ" META_RECOMMENDS_JSON="$RJ"
    export META_SUGGESTS_JSON="$SJ" META_CONFLICTS_JSON="$CJ" META_PROVIDES_JSON="$PVJ"

    generate_metadata "$WD/pkg/metadata.json"

    echo -e "  ${Y}[5/5]${RE} $(t build.packing)"
    local OF="${PKG_NAME}_${PKG_VERSION}_${PKG_ARCH}.nux"
    export XZ_OPT="${XZ_OPT:--T0 -3}"
    tar --create --xz --preserve-permissions --file "$PACKAGES_DIR/$OF" \
        -C "$WD/pkg" metadata.json files scripts control 2>/dev/null

    local NH; NH="$(sha256sum "$PACKAGES_DIR/$OF" | cut -d' ' -f1)"
    echo -e "  ${G}$(t build.done):${RE} $OF ${DIM}[$FINAL_CLASS]${RE}"
    echo "    sha256: $NH"
    log_ok "BUILD: $OF [class=$FINAL_CLASS, managed_by=nux]"
    rm -rf "$WD"
    return 0
}

# ══════════════════════════════════════════════════════════════════
# DEPENDENCY RESOLUTION
# ══════════════════════════════════════════════════════════════════

resolve_deps() {
    local pkg_name="$1"
    echo -e "${C}[dep-resolver]${RE} $(t build.deps_resolving) $pkg_name"
    debian_update || return 1

    local all_deps; all_deps="$(debian_depends_recursive "$pkg_name")"
    if [ -z "$all_deps" ]; then
        echo -e "${Y}$(t build.deps_none)${RE}"
        return 0
    fi

    local DDW; DDW="$(mktemp -d /tmp/nux_deps_XXXXXX)"; register_temp "$DDW"
    local total=0 skipped=0 downloaded=0 failed=0
    local dc cur=0; dc="$(printf '%s\n' "$all_deps" | sed '/^$/d' | wc -l)"

    echo -e "${C}$(t build.deps_checking) ($dc)...${RE}"

    while IFS= read -r dep; do
        [ -z "$dep" ] && continue
        total=$((total + 1)); cur=$((cur + 1))
        progress_bar "$cur" "$dc" "Deps"
        if already_in_repo "$dep"; then skipped=$((skipped + 1)); continue; fi
        if debian_download "$dep" "$DDW" 2>/dev/null; then
            downloaded=$((downloaded + 1))
        else
            failed=$((failed + 1))
        fi
    done <<< "$all_deps"

    echo ""
    echo -e "${C}Total=$total | Repo=$skipped | Downloaded=$downloaded | Failed=$failed${RE}"

    local dd=("$DDW"/*.deb)
    if [ ${#dd[@]} -gt 0 ]; then
        echo -e "${C}$(t build.deps_converting) ${Y}[class=base]${RE}..."
        for df in "${dd[@]}"; do
            [ -f "$df" ] || continue
            build_one "$df" "base" || log_error "Dep build failed: $df"
        done
    else
        echo -e "${Y}$(t build.deps_nonew)${RE}"
    fi
    rm -rf "$DDW"
}

