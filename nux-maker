# ══════════════════════════════════════════════════════════════════
# DEPENDENCY PARSER
# ══════════════════════════════════════════════════════════════════

json_list_from_field() {
    local raw="$1" field="$2" keep_all="$3"
    python3 - "$raw" "$field" "$keep_all" <<'PYPARSE'
import json, re, sys
raw = sys.argv[1].strip()
field = sys.argv[2].strip()
keep_all = sys.argv[3].strip() == "1"
PKG_RE = re.compile(r"^[a-z0-9][a-z0-9+.-]*$")
if not raw:
    print("[]"); sys.exit(0)
IGNORE = [r"^.*-keyring$", r"^apt-transport-https$", r"^software-properties-common$",
          r"^lsb-release$", r"^gnupg2?$", r"^dirmngr$", r"^debian-archive-keyring$",
          r"^ubuntu-keyring$", r"^nucora-archive-keyring$"]
def norm(d):
    d = re.sub(r"\s*\(.*?\)","",d).strip()
    d = re.sub(r"\s*\[.*?\]","",d).strip()
    d = re.sub(r":[A-Za-z0-9_-]+$","",d).strip()
    return d
def ign(n):
    if keep_all: return False
    if field not in ("depends","pre_depends","recommends","suggests"): return False
    return any(re.match(p,n) for p in IGNORE)
items = []
for expr in raw.replace("\n"," ").replace("\r"," ").split(","):
    expr = expr.strip()
    if not expr: continue
    sel = None
    for alt in expr.split("|"):
        n = norm(alt.strip())
        if n and PKG_RE.fullmatch(n) and not ign(n):
            sel = n; break
    if sel and sel not in items: items.append(sel)
print(json.dumps(items, ensure_ascii=False))
PYPARSE
}

# ══════════════════════════════════════════════════════════════════
# SCRIPT WRAPPER
# ══════════════════════════════════════════════════════════════════

create_script_wrapper() {
    local script_type="$1" pkg_name="$2" source_script="$3" target_dir="$4"
    local wrapper_name default_arg
    case "$script_type" in
        preinst)  wrapper_name="pre-install.sh";  default_arg="install"   ;;
        postinst) wrapper_name="post-install.sh"; default_arg="configure" ;;
        prerm)    wrapper_name="pre-remove.sh";   default_arg="remove"    ;;
        postrm)   wrapper_name="post-remove.sh";  default_arg="remove"    ;;
        *) return 1 ;;
    esac
    [ ! -f "$source_script" ] && return 0
    cp "$source_script" "$target_dir/.${script_type}.real"
    chmod +x "$target_dir/.${script_type}.real"
    cat > "$target_dir/$wrapper_name" <<WRAPPER
#!/bin/sh
export DPKG_MAINTSCRIPT_PACKAGE="$pkg_name"
export DPKG_MAINTSCRIPT_NAME="$script_type"
export DPKG_ADMINDIR="/var/lib/dpkg"
[ "\$#" -eq 0 ] && set -- "$default_arg"
exec /bin/sh "\$(dirname "\$0")/.${script_type}.real" "\$@"
WRAPPER
    chmod +x "$target_dir/$wrapper_name"
}

