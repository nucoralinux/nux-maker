LANG_CURRENT="tr"

detect_language() {
    if [ -f "$CONFIG_FILE" ]; then
        local cfg_lang
        cfg_lang="$(python3 -c "import json; print(json.load(open('$CONFIG_FILE')).get('language','tr'))" 2>/dev/null || echo "tr")"
        LANG_CURRENT="$cfg_lang"
    else
        local sys_lang="${LANG:-en_US}"
        if [[ "$sys_lang" == tr* ]]; then
            LANG_CURRENT="tr"
        else
            LANG_CURRENT="en"
        fi
    fi
}

