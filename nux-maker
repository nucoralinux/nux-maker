    idx = json.load(f)
pkgs_dir = sys.argv[2]
ok = missing = mismatch = 0
for name, pdata in idx.get("packages", {}).items():
    for ver, info in pdata.get("versions", {}).items():
        fn = info.get("filename", "")
        if fn.startswith("packages/"):
            fn = fn[len("packages/"):]
        path = os.path.join(pkgs_dir, fn)
        if not os.path.exists(path):
            print(f"  ✗ MISSING: {name} {ver} → {fn}")
            missing += 1
            continue
        expected = info.get("sha256", "")
        if expected:
            h = hashlib.sha256()
            with open(path, "rb") as f:
                for chunk in iter(lambda: f.read(1048576), b""):
                    h.update(chunk)
            if h.hexdigest() != expected:
                print(f"  ✗ MISMATCH: {name} {ver}")
                mismatch += 1
                continue
        ok += 1
print(f"\n  ✓ OK: {ok} | ✗ Missing: {missing} | ✗ Mismatch: {mismatch}")
PYVERIFY
}

