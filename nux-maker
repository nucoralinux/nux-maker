# ══════════════════════════════════════════════════════════════════
# MAIN
# ══════════════════════════════════════════════════════════════════

# Config varsa repo dizinlerini oluştur
if [ -f "$CONFIG_FILE" ]; then
    mkdir -p "$PACKAGES_DIR" "$CACHE_DIR" "$LOG_DIR" 2>/dev/null || true
fi

# Argüman yoksa help
if [ $# -eq 0 ]; then
    show_help
    exit 0
fi

CMD="$1"; shift

case "$CMD" in
    setup)
        run_setup
        ;;

    build)
        # Config kontrolü
        if [ ! -f "$CONFIG_FILE" ]; then
            echo -e "${R}Config not found. Run: sudo nux-maker setup${RE}"
            exit 1
        fi

        # Argümanları parse et
        while [ $# -gt 0 ]; do
            case "$1" in
                --with-deps)    WITH_DEPS=1 ;;
                --no-update)    NO_UPDATE=1 ;;
                --dry-run)      DRY_RUN=1 ;;
                --clear-cache)  CLEAR_CACHE=1 ;;
                --keep-all-deps) KEEP_ALL_DEPS=1 ;;
                --class)
                    shift
                    [[ "$1" =~ ^(app|base|tool)$ ]] || { echo -e "${R}Invalid class${RE}"; exit 1; }
                    FORCE_CLASS="$1"
                    ;;
                --max-depth)
                    shift
                    MAX_DEPTH="$1"
                    ;;
                *.deb) DEB_FILES+=("$1") ;;
                *) PKG_NAMES+=("$1") ;;
            esac
            shift
        done

        cache_init
        FAIL=0

        # Paket adı ile
        if [ ${#PKG_NAMES[@]} -gt 0 ]; then
            [ "$WITH_DEPS" -eq 0 ] && { echo -e "${R}--with-deps required for package names${RE}"; exit 1; }
            debian_update || exit 1
            for pn in "${PKG_NAMES[@]}"; do
                echo -e "${C}[apt-mode]${RE} $pn..."
                if already_in_repo "$pn"; then
                    echo -e "${G}[=]${RE} $pn already in repo"
                else
                    MD="$(mktemp -d /tmp/nux_main_XXXXXX)"; register_temp "$MD"
                    if debian_download "$pn" "$MD" 2>/dev/null; then
                        for deb in "$MD"/*.deb; do
                            [ -f "$deb" ] && {
                                local mc; mc="$(determine_class "$pn" "app")"
                                build_one "$deb" "$mc" || FAIL=1
                            }
                        done
                    else
                        echo -e "${R}Download failed: $pn${RE}"; FAIL=1
                    fi
                    rm -rf "$MD"
                fi
                [ "$WITH_DEPS" -eq 1 ] && { resolve_deps "$pn" || FAIL=1; }
            done
        fi

        # .deb dosyası ile
        if [ ${#DEB_FILES[@]} -gt 0 ]; then
            for deb in "${DEB_FILES[@]}"; do
                local dpn; dpn="$(dpkg-deb -f "$deb" Package 2>/dev/null || true)"
                local dc; dc="$(determine_class "${dpn:-unknown}" "app")"
                build_one "$deb" "$dc" || FAIL=1
                [ "$WITH_DEPS" -eq 1 ] && [ -n "$dpn" ] && { resolve_deps "$dpn" || true; }
            done
        fi

        [ "$NO_UPDATE" -eq 0 ] && index_rebuild
        exit "$FAIL"
        ;;

    index)
        [ ! -f "$CONFIG_FILE" ] && { echo -e "${R}Run setup first${RE}"; exit 1; }
        case "${1:-}" in
            rebuild) cache_init; index_rebuild ;;
            info)    index_info ;;
            verify)  index_verify ;;
            *)       echo "Usage: nux-maker index rebuild|info|verify" ;;
        esac
        ;;

    repo)
        [ ! -f "$CONFIG_FILE" ] && { echo -e "${R}Run setup first${RE}"; exit 1; }
        case "${1:-}" in
            stats)  repo_stats ;;
            audit)  repo_audit ;;
            repair) repo_repair ;;
            clean)  repo_clean ;;
            *)      echo "Usage: nux-maker repo stats|audit|repair|clean" ;;
        esac
        ;;

    classify)
        [ ! -f "$CONFIG_FILE" ] && { echo -e "${R}Run setup first${RE}"; exit 1; }
        run_classify "${1:---all}"
        ;;

    nginx)
        case "${1:-}" in
            status)  nginx_status ;;
            test)    nginx_test ;;
            restart) nginx_restart ;;
            *)       echo "Usage: nux-maker nginx status|test|restart" ;;
        esac
        ;;

    scan-ubuntu)
        [ ! -f "$CONFIG_FILE" ] && { echo -e "${R}Run setup first${RE}"; exit 1; }
        scan_ubuntu
        ;;

    purge-ubuntu)
        [ ! -f "$CONFIG_FILE" ] && { echo -e "${R}Run setup first${RE}"; exit 1; }
        purge_ubuntu
        ;;

    config)
        case "${1:-}" in
            show) config_show ;;
            edit) config_edit ;;
            *)    echo "Usage: nux-maker config show|edit" ;;
        esac
        ;;

    help|--help|-h)
        show_help
        ;;

    version|--version)
        echo "nux-maker v${MAKER_VERSION}"
        ;;

    *)
        echo -e "${R}Unknown command: $CMD${RE}"
        echo "Run: nux-maker help"
        exit 1
        ;;
esac
