# ══════════════════════════════════════════════════════════════════
# TOOL WHITELIST
# ══════════════════════════════════════════════════════════════════

is_tool_package() {
    local pkg="$1"
    [[ "$pkg" == "nux" ]] && return 0
    [[ "$pkg" == nucora-* ]] && return 0
    return 1
}

determine_class() {
    local pkg="$1"
    local default_class="${2:-app}"
    if is_tool_package "$pkg"; then
        echo "tool"
        return
    fi
    echo "$default_class"
}

# ══════════════════════════════════════════════════════════════════
# YARDIMCILAR
# ══════════════════════════════════════════════════════════════════

TEMP_DIRS=()

cleanup_all() {
    local dir
    for dir in "${TEMP_DIRS[@]}"; do
        [ -n "${dir:-}" ] && [ -d "$dir" ] && rm -rf "$dir"
    done
}

trap cleanup_all EXIT INT TERM

register_temp() { TEMP_DIRS+=("$1"); }

log_msg() {
    local level="$1"; shift
    mkdir -p "$LOG_DIR" 2>/dev/null || true
    printf '[%s] [%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$level" "$*" >> "$BUILD_LOG" 2>/dev/null || true
}

log_info()  { log_msg INFO  "$@"; }
log_warn()  { log_msg WARN  "$@"; }
log_error() { log_msg ERROR "$@"; }
log_ok()    { log_msg OK    "$@"; }

progress_bar() {
    local current="$1" total="$2" label="${3:-Processing}"
    local width=32
    [ "$total" -le 0 ] && return 0
    local pct=$(( current * 100 / total ))
    local filled=$(( current * width / total ))
    local empty=$(( width - filled ))
    local bar=""
    local i
    for ((i=0; i<filled; i++)); do bar+="█"; done
    for ((i=0; i<empty; i++)); do bar+="░"; done
    printf "\r  ${C}%s${RE} [${G}%s${RE}] %3d%% (%d/%d)" "$label" "$bar" "$pct" "$current" "$total"
    [ "$current" -eq "$total" ] && echo ""
}

confirm() {
    local msg="$1"
    local yn
    yn="$(t yes_no)"
    read -rp "$(echo -e "  ${Y}[?]${RE} $msg $yn: ")" answer
    local chars
    chars="$(t yes_chars)"
    [[ -z "$answer" || "$chars" == *"$answer"* ]]
}

# ══════════════════════════════════════════════════════════════════
# CACHE
# ══════════════════════════════════════════════════════════════════

cache_init() {
    mkdir -p "$CACHE_DIR" 2>/dev/null || true
    [ "$CLEAR_CACHE" -eq 1 ] && { rm -f "$CACHE_DB"; echo -e "${G}✓ Cache$(t done)${RE}"; }
    [ "$NO_CACHE" -eq 1 ] && rm -f "$CACHE_DB"
    [ -f "$CACHE_DB" ] || printf '{}' > "$CACHE_DB"
}

# ══════════════════════════════════════════════════════════════════
# SETUP WIZARD
# ══════════════════════════════════════════════════════════════════

run_setup() {
    if [ "$EUID" -ne 0 ]; then
        echo -e "${R}$(t root_required)${RE}"
        exit 1
    fi

    echo -e "${C}"
    echo "╔══════════════════════════════════════════════════════╗"
    echo "║  🚀 $(t setup.title) v${MAKER_VERSION}"
    echo "║"
    echo "║  $(t setup.welcome)"
    echo "╚══════════════════════════════════════════════════════╝"
    echo -e "${RE}"

    # Adım 0 — Dil
    echo -e "  ${W}$(t setup.step) 0/5 — $(t setup.lang)${RE}"
    echo -e "  ${DIM}────────────────────────────────────────${RE}"
    echo -e "  $(t setup.lang_desc)"
    echo ""
    echo -e "  1) Türkçe"
    echo -e "  2) English"
    echo ""
    read -rp "  $(t setup.select) [1]: " lang_choice
    case "${lang_choice:-1}" in
        2) LANG_CURRENT="en" ;;
        *) LANG_CURRENT="tr" ;;
    esac
    echo ""

    # Adım 1 — Repo dizini
    echo -e "  ${W}$(t setup.step) 1/5 — $(t setup.repo_dir)${RE}"
    echo -e "  ${DIM}────────────────────────────────────────${RE}"
    echo -e "  $(t setup.repo_dir_desc)"
    echo ""
    read -rp "  [$DEFAULT_REPO_ROOT]: " repo_root
    repo_root="${repo_root:-$DEFAULT_REPO_ROOT}"
    echo -e "  ${G}✓${RE} $repo_root"
    echo ""

    # Adım 2 — Repo bilgileri
    echo -e "  ${W}$(t setup.step) 2/5 — $(t setup.repo_info)${RE}"
    echo -e "  ${DIM}────────────────────────────────────────${RE}"
    read -rp "  $(t setup.repo_name) [my-nux-repo]: " repo_name
    repo_name="${repo_name:-my-nux-repo}"
    read -rp "  $(t setup.repo_desc) [Nux Package Repository]: " repo_desc
    repo_desc="${repo_desc:-Nux Package Repository}"
    read -rp "  $(t setup.repo_maintainer) [Admin]: " repo_maintainer
    repo_maintainer="${repo_maintainer:-Admin}"
    echo ""

    # Adım 3 — Web sunucu
    echo -e "  ${W}$(t setup.step) 3/5 — $(t setup.web)${RE}"
    echo -e "  ${DIM}────────────────────────────────────────${RE}"
    echo -e "  $(t setup.web_desc)"
    echo -e "  ${DIM}$(t setup.web_example)${RE}"
    echo ""
    read -rp "  $(t setup.domain): " web_domain
    if [ -z "$web_domain" ]; then
        echo -e "  ${R}$(t error): Domain/IP gerekli${RE}"
        exit 1
    fi
    echo ""

    echo -e "  $(t setup.https)"
    echo -e "  1) $(t setup.https_le)"
    echo -e "  2) $(t setup.https_self)"
    echo -e "  3) $(t setup.https_no)"
    echo ""
    read -rp "  $(t setup.select) [3]: " ssl_choice
    ssl_choice="${ssl_choice:-3}"

    local ssl_type="none"
    local web_port=80
    local web_protocol="http"
    case "$ssl_choice" in
        1) ssl_type="letsencrypt"; web_port=443; web_protocol="https" ;;
        2) ssl_type="selfsigned"; web_port=443; web_protocol="https" ;;
        *) ssl_type="none"; web_port=80; web_protocol="http" ;;
    esac
    echo ""

    read -rp "  $(t setup.port) [$web_port]: " custom_port
    web_port="${custom_port:-$web_port}"
    echo ""

    # Adım 4 — Mimari
    echo -e "  ${W}$(t setup.step) 4/5 — $(t setup.arch)${RE}"
    echo -e "  ${DIM}────────────────────────────────────────${RE}"
    echo -e "  $(t setup.arch_desc)"
    echo -e "  1) amd64"
    echo -e "  2) arm64"
    echo -e "  3) i386"
    echo ""
    read -rp "  $(t setup.select) [1]: " arch_choice
    local target_arch="amd64"
    case "${arch_choice:-1}" in
        2) target_arch="arm64" ;;
        3) target_arch="i386" ;;
        *) target_arch="amd64" ;;
    esac
    echo ""

    # Adım 5 — Özet
    echo -e "  ${W}$(t setup.step) 5/5 — $(t setup.summary)${RE}"
    echo -e "  ${DIM}────────────────────────────────────────${RE}"
    echo ""
    echo -e "╔══════════════════════════════════════════════════════╗"
    echo -e "║  $(t setup.summary)                                  "
    echo -e "╠══════════════════════════════════════════════════════╣"
    echo -e "║  📁 Repo dizini   : $repo_root"
    echo -e "║  📛 Repo adı      : $repo_name"
    echo -e "║  👤 Bakımcı       : $repo_maintainer"
    echo -e "║  🌐 Domain/IP     : $web_domain"
    echo -e "║  🔒 SSL           : $ssl_type"
    echo -e "║  🔌 Port          : $web_port"
    echo -e "║  🏗️  Mimari        : $target_arch"
    echo -e "║  🌐 Dil           : $LANG_CURRENT"
    echo -e "║"
    echo -e "║  Oluşturulacak yapı:"
    echo -e "║  $repo_root/"
    echo -e "║  ├── packages/"
    echo -e "║  ├── .cache/"
    echo -e "║  ├── .logs/"
    echo -e "║  ├── index.json"
    echo -e "║  └── repo.json"
    echo -e "╚══════════════════════════════════════════════════════╝"
    echo ""

    if ! confirm "$(t setup.confirm)"; then
        echo -e "  ${Y}$(t cancel)${RE}"
        exit 0
    fi

    echo ""

    # ── Dizinler ──
    echo -e "  ⠋ $(t setup.creating)"
    mkdir -p "$repo_root/packages" "$repo_root/.cache" "$repo_root/.logs"
    chmod 755 "$repo_root" "$repo_root/packages"
    echo -e "  ${G}✓${RE} $repo_root/packages"
    echo -e "  ${G}✓${RE} $repo_root/.cache"
    echo -e "  ${G}✓${RE} $repo_root/.logs"

    # ── repo.json ──
    python3 -c "
import json
from datetime import datetime
repo = {
    'name': '$repo_name',
    'description': '$repo_desc',
    'maintainer': '$repo_maintainer',
    'url': '${web_protocol}://${web_domain}',
    'created_at': datetime.utcnow().isoformat() + 'Z',
    'nux_maker_version': '$MAKER_VERSION'
}
with open('$repo_root/repo.json', 'w') as f:
    json.dump(repo, f, indent=2, ensure_ascii=False)
"
    echo -e "  ${G}✓${RE} repo.json"

    # ── index.json ──
    echo -e "  ⠋ $(t setup.index_creating)"
    python3 -c "
import json
from datetime import datetime
index = {
    'generated_at': datetime.utcnow().isoformat() + 'Z',
    'generator': 'nux-maker/$MAKER_VERSION',
    'package_count': 0,
    'version_count': 0,
    'packages': {}
}
with open('$repo_root/index.json', 'w') as f:
    json.dump(index, f, indent=2, ensure_ascii=False)
"
    echo -e "  ${G}✓${RE} index.json"

    # ── Nginx config ──
    echo -e "  ⠋ $(t setup.nginx_creating)"

    local nginx_conf="/etc/nginx/sites-available/nux-repo-${repo_name}"
    local nginx_link="/etc/nginx/sites-enabled/nux-repo-${repo_name}"

    if [ "$ssl_type" = "none" ]; then
        cat > "$nginx_conf" <<NGINXEOF
server {
    listen ${web_port};
    server_name ${web_domain};

    root ${repo_root};
    autoindex on;
    autoindex_format json;

    location / {
        try_files \$uri \$uri/ =404;
    }

    location /packages/ {
        types {
            application/octet-stream nux;
        }
        add_header Access-Control-Allow-Origin *;
    }

    location /index.json {
        add_header Cache-Control "no-cache, must-revalidate";
        add_header Access-Control-Allow-Origin *;
    }

    access_log /var/log/nginx/nux-repo-${repo_name}.access.log;
    error_log /var/log/nginx/nux-repo-${repo_name}.error.log;
}
NGINXEOF

    elif [ "$ssl_type" = "selfsigned" ]; then
        echo -e "  ⠋ $(t setup.ssl_generating)"
        local ssl_dir="/etc/nginx/ssl/nux-repo-${repo_name}"
        mkdir -p "$ssl_dir"
        openssl req -x509 -nodes -days 3650 \
            -newkey rsa:2048 \
            -keyout "$ssl_dir/key.pem" \
            -out "$ssl_dir/cert.pem" \
            -subj "/CN=${web_domain}" \
            >/dev/null 2>&1
        echo -e "  ${G}✓${RE} Self-signed SSL"

        cat > "$nginx_conf" <<NGINXEOF
server {
    listen 80;
    server_name ${web_domain};
    return 301 https://\$host\$request_uri;
}

server {
    listen ${web_port} ssl http2;
    server_name ${web_domain};

    ssl_certificate ${ssl_dir}/cert.pem;
    ssl_certificate_key ${ssl_dir}/key.pem;

    root ${repo_root};
    autoindex on;
    autoindex_format json;

    location / {
        try_files \$uri \$uri/ =404;
    }

    location /packages/ {
        types {
            application/octet-stream nux;
        }
        add_header Access-Control-Allow-Origin *;
    }

    location /index.json {
        add_header Cache-Control "no-cache, must-revalidate";
        add_header Access-Control-Allow-Origin *;
    }

    access_log /var/log/nginx/nux-repo-${repo_name}.access.log;
    error_log /var/log/nginx/nux-repo-${repo_name}.error.log;
}
NGINXEOF

    elif [ "$ssl_type" = "letsencrypt" ]; then
        # Önce HTTP ile kur, sonra certbot çalıştır
        cat > "$nginx_conf" <<NGINXEOF
server {
    listen 80;
    server_name ${web_domain};

    root ${repo_root};
    autoindex on;

    location / {
        try_files \$uri \$uri/ =404;
    }

    location /packages/ {
        types {
            application/octet-stream nux;
        }
        add_header Access-Control-Allow-Origin *;
    }

    location /index.json {
        add_header Cache-Control "no-cache, must-revalidate";
        add_header Access-Control-Allow-Origin *;
    }
}
NGINXEOF
    fi

    echo -e "  ${G}✓${RE} Nginx config: $nginx_conf"

    # ── Nginx etkinleştir ──
    echo -e "  ⠋ $(t setup.nginx_enabling)"
    ln -sf "$nginx_conf" "$nginx_link" 2>/dev/null || true

    # Default site çakışma kontrolü
    if [ -f /etc/nginx/sites-enabled/default ]; then
        rm -f /etc/nginx/sites-enabled/default 2>/dev/null || true
    fi

    nginx -t >/dev/null 2>&1 && {
        systemctl reload nginx 2>/dev/null || systemctl restart nginx 2>/dev/null || true
        echo -e "  ${G}✓${RE} Nginx reload"
    } || {
        echo -e "  ${R}✗${RE} Nginx config hatası! Manuel kontrol edin: nginx -t"
    }

    # Let's Encrypt
    if [ "$ssl_type" = "letsencrypt" ]; then
        echo -e "  ⠋ $(t setup.ssl_obtaining)"
        certbot --nginx -d "$web_domain" --non-interactive --agree-tos \
            --register-unsafely-without-email >/dev/null 2>&1 && {
            echo -e "  ${G}✓${RE} Let's Encrypt SSL"
        } || {
            echo -e "  ${Y}⚠${RE} SSL alınamadı. Manuel deneyin: certbot --nginx -d $web_domain"
        }
    fi

    # ── Config kaydet ──
    echo -e "  ⠋ $(t setup.config_saving)"
    mkdir -p /etc/nux-maker

    python3 -c "
import json
config = {
    'version': '$MAKER_VERSION',
    'language': '$LANG_CURRENT',
    'repo': {
        'name': '$repo_name',
        'description': '$repo_desc',
        'maintainer': '$repo_maintainer',
        'root': '$repo_root',
        'packages_dir': '${repo_root}/packages',
        'cache_dir': '${repo_root}/.cache',
        'log_dir': '${repo_root}/.logs'
    },
    'web': {
        'domain': '$web_domain',
        'protocol': '$web_protocol',
        'port': int('$web_port'),
        'ssl_type': '$ssl_type',
        'nginx_config': '$nginx_conf'
    },
    'debian': {
        'suite': 'trixie',
        'arch': '$target_arch',
        'mirror': 'http://deb.debian.org/debian',
        'security': 'http://security.debian.org/debian-security'
    },
    'build': {
        'xz_threads': 0,
        'xz_level': 3,
        'max_repair_depth': 10
    }
}
with open('/etc/nux-maker/config.json', 'w') as f:
    json.dump(config, f, indent=2, ensure_ascii=False)
"
    echo -e "  ${G}✓${RE} /etc/nux-maker/config.json"

    # ── Sonuç ──
    local repo_url="${web_protocol}://${web_domain}"
    echo ""
    echo -e "╔══════════════════════════════════════════════════════╗"
    echo -e "║                                                      ║"
    echo -e "║  🎉 $(t setup.done)                                  "
    echo -e "║                                                      ║"
    echo -e "║  📦 Paket ekle:                                      ║"
    echo -e "║     nux-maker build discord.deb                      ║"
    echo -e "║     nux-maker build --with-deps zoom                 ║"
    echo -e "║                                                      ║"
    echo -e "║  📋 Index güncelle:                                  ║"
    echo -e "║     nux-maker index rebuild                          ║"
    echo -e "║                                                      ║"
    echo -e "║  📊 Repo durumu:                                     ║"
    echo -e "║     nux-maker repo stats                             ║"
    echo -e "║                                                      ║"
    echo -e "║  🌐 Repo URL:                                        ║"
    echo -e "║     ${repo_url}                                       "
    echo -e "║                                                      ║"
    echo -e "║  🔗 Client tarafında repo eklemek için:              ║"
    echo -e "║     nux repo add ${repo_name} ${repo_url}             "
    echo -e "║                                                      ║"
    echo -e "╚══════════════════════════════════════════════════════╝"
    echo ""
    echo -e "${DIM}$(t about.dev)${RE}"
    echo -e "${DIM}$(t about.by)${RE}"
    echo -e "${DIM}$(t about.motto)${RE}"
    echo ""
}

