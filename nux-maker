# UBUNTU SCAN/PURGE
# ══════════════════════════════════════════════════════════════════

scan_ubuntu() {
    cache_init
    python3 - "$PACKAGES_DIR" "$CACHE_DB" "scan" <<'PYUBU'
import json, os, sys, tarfile
pd,cf,mode = sys.argv[1],sys.argv[2],sys.argv[3]
cache = {}
if os.path.exists(cf):
    try:
        with open(cf) as f: cache = json.load(f)
    except: pass
files = sorted(f for f in os.listdir(pd) if f.endswith(".nux"))
ubu = []
for fn in files:
    meta = None
    if fn in cache and cache[fn].get("name"): meta = cache[fn]
    else:
        try:
            with tarfile.open(os.path.join(pd,fn),"r:*") as tar:
                fo = tar.extractfile(tar.getmember("metadata.json"))
                if fo: meta = json.load(fo)
        except: continue
    if not meta: continue
    reasons = []
    if "ubuntu" in meta.get("version","").lower(): reasons.append("version")
    m = meta.get("maintainer","").lower()
    if "ubuntu" in m or "canonical" in m: reasons.append("maintainer")
    if reasons:
        ubu.append({"name":meta.get("name",""),"filename":fn,"reasons":reasons,
                     "class":meta.get("class","app")})
print(f"  Total: {len(files)} | Ubuntu: {len(ubu)}")
if ubu:
    for p in sorted(ubu, key=lambda x:x["name"]):
        prot = " [PROTECTED]" if p["class"]=="tool" else ""
        print(f"  {p['name']:<30} [{p['class']}]{prot} ({', '.join(p['reasons'])})")
if mode == "purge":
    d = [p for p in ubu if p["class"] != "tool"]
    for p in d:
        try:
            os.remove(os.path.join(pd,p["filename"]))
            print(f"  DELETED: {p['filename']}")
        except: pass
    print(f"  Deleted: {len(d)}")
elif ubu:
    print("  To purge: nux-maker purge-ubuntu")
PYUBU
}

purge_ubuntu() {
    cache_init
    python3 - "$PACKAGES_DIR" "$CACHE_DB" "purge" <<'PYUBU2'
import json, os, sys, tarfile
pd,cf,mode = sys.argv[1],sys.argv[2],sys.argv[3]
cache = {}
if os.path.exists(cf):
    try:
        with open(cf) as f: cache = json.load(f)
    except: pass
files = sorted(f for f in os.listdir(pd) if f.endswith(".nux"))
ubu = []
for fn in files:
    meta = None
    if fn in cache and cache[fn].get("name"): meta = cache[fn]
    else:
        try:
            with tarfile.open(os.path.join(pd,fn),"r:*") as tar:
                fo = tar.extractfile(tar.getmember("metadata.json"))
                if fo: meta = json.load(fo)
        except: continue
    if not meta: continue
    reasons = []
    if "ubuntu" in meta.get("version","").lower(): reasons.append("version")
    m = meta.get("maintainer","").lower()
    if "ubuntu" in m or "canonical" in m: reasons.append("maintainer")
    if reasons:
        ubu.append({"name":meta.get("name",""),"filename":fn,"class":meta.get("class","app")})
d = [p for p in ubu if p["class"] != "tool"]
for p in d:
    try:
        os.remove(os.path.join(pd,p["filename"]))
        print(f"  DELETED: {p['filename']}")
    except: pass
print(f"\n  Deleted: {len(d)} | Protected: {len(ubu)-len(d)}")
PYUBU2
    rm -f "$CACHE_DB"; printf '{}' > "$CACHE_DB"
    index_rebuild
}

