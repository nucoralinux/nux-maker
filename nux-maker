    port="$(cfg web.port "80")"
    ssl_type="$(cfg web.ssl_type "none")"

    local running="false" config_ok="false"
    systemctl is-active nginx >/dev/null 2>&1 && running="true"
    nginx -t >/dev/null 2>&1 && config_ok="true"

    local run_icon run_text cfg_icon cfg_text
    if [ "$running" = "true" ]; then
        run_icon="${G}✅${RE}"; run_text="${G}$(t nginx.running)${RE}"
    else
        run_icon="${R}❌${RE}"; run_text="${R}$(t nginx.stopped)${RE}"
    fi
    if [ "$config_ok" = "true" ]; then
        cfg_icon="${G}✅${RE}"; cfg_text="${G}$(t nginx.config_ok)${RE}"
    else
        cfg_icon="${R}❌${RE}"; cfg_text="${R}$(t nginx.config_err)${RE}"
    fi

    echo -e "\n╔══════════════════════════════════════════╗"
    echo -e "║  $(t nginx.status_title)"
    echo -e "╠══════════════════════════════════════════╣"
    echo -e "║  Status  : $run_icon $run_text"
    echo -e "║  Config  : $cfg_icon $cfg_text"
    echo -e "║  Domain  : $domain"
    echo -e "║  Port    : $port"
    echo -e "║  SSL     : $ssl_type"
    echo -e "║  Root    : $REPO_ROOT"
    echo -e "╚══════════════════════════════════════════╝\n"
}

nginx_test() {
    echo -e "  ⠋ $(t nginx.testing)"
    nginx -t 2>&1 | while IFS= read -r line; do echo "    $line"; done
    echo ""

    local url
    url="$(cfg web.protocol "http")://$(cfg web.domain "localhost")/index.json"
    echo -e "  ⠋ $(t nginx.repo_testing)"
    local code
    code="$(curl -sI -o /dev/null -w "%{http_code}" "$url" 2>/dev/null || echo "000")"
    if [ "$code" = "200" ]; then
        echo -e "  ${G}✅${RE} $url → $code"
    else
        echo -e "  ${R}❌${RE} $url → $code"
    fi
    echo ""
}

nginx_restart() {
    systemctl restart nginx 2>/dev/null && echo -e "${G}✓ Nginx restarted${RE}" || echo -e "${R}Nginx restart failed${RE}"
}

