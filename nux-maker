run_classify() {
    local target="${1:---all}"
    echo -e "${C}$(t classify.title)${RE}"

    python3 - "$PACKAGES_DIR" "$target" <<'PYCLASS'
import json, os, sys, tarfile, tempfile, shutil, re
pd = sys.argv[1]
target = sys.argv[2]

TOOL_PKG = {"nux"}
TOOL_PFX = ("nucora-",)
BASE_SEC = {"libs","libdevel","oldlibs","debug","base","perl","python","x11","fonts","devel"}
BASE_PRI = {"required","important"}
BASE_PAT = [re.compile(p) for p in [
    r"^lib[a-z]", r"^gir1\.2-", r"^gpg", r"^dbus", r"^ibus", r"^x11-", r"^xfonts-",
    r"^xbitmaps", r"^xdg-", r"^xkb-", r"^fonts-", r"^fontconfig", r"^openssl",
    r"^ca-certificates", r"^perl", r"^python3", r"^default-jre", r"^openjdk-",
    r"^mesa-", r"^systemd", r"^sysvinit", r"^udev", r"^eudev", r"^passwd",
    r"^adduser", r"^base-files", r"^base-passwd", r"^coreutils", r"^util-linux",
    r"^bash$", r"^dash$", r"^tar$", r"^gzip$", r"^bzip2", r"^xz-utils", r"^zlib",
    r"^sed$", r"^grep$", r"^gawk$", r"^mawk$", r"^findutils", r"^diffutils",
    r"^debconf", r"^dpkg", r"^apt$", r"^apt-", r"^sensible-utils", r"^debianutils",
    r"^hostname$", r"^ncurses-", r"^init$", r"^init-", r"^lsb-base", r"^netbase",
    r"^procps", r"^mount$", r"^shared-mime-info", r"^hicolor-icon-theme",
    r"^adwaita-icon-theme", r"^at-spi2-", r"^iso-codes", r"^media-types",
    r"^readline-common", r"^ucf$", r"^unzip$", r"^wget$", r"^dconf-",
    r"^gsettings-desktop-schemas", r"^gtk-update-icon-cache", r"^poppler-data",
    r"^timgm6mb-soundfont", r"^login"
]]

def classify(name, meta):
    if name in TOOL_PKG: return "tool"
    for p in TOOL_PFX:
        if name.startswith(p): return "tool"
    if str(meta.get("essential","")).lower() == "yes": return "base"
    if meta.get("priority","").lower() in BASE_PRI: return "base"
    if meta.get("section","").lower() in BASE_SEC: return "base"
    for pat in BASE_PAT:
        if pat.match(name): return "base"
    return "app"

files = sorted(f for f in os.listdir(pd) if f.endswith(".nux"))
if not files:
    print("  No packages."); sys.exit(0)

CC = {"app":"\033[1;32m","base":"\033[1;33m","tool":"\033[1;35m"}
RS = "\033[0m"
updated = skipped = errors = 0

for i, fn in enumerate(files, 1):
    fp = os.path.join(pd, fn)
    try:
        with tarfile.open(fp, "r:*") as tar:
            m = tar.getmember("metadata.json")
            fo = tar.extractfile(m)
            meta = json.load(fo) if fo else {}
            names = tar.getnames()
        name = meta.get("name","")
        if not name: errors += 1; continue
        old = meta.get("class","")
        new = classify(name, meta)
        if old == new: skipped += 1; continue
        meta["class"] = new
        meta["managed_by"] = "nux"
        if new == "tool": meta["protected"] = True
        meta["nux_format_version"] = "4.5"
        if new == "base": meta["source_type"] = "debian-dependency"
        elif new == "tool": meta["source_type"] = "native"
        elif "source_type" not in meta: meta["source_type"] = "deb-import"
        td = tempfile.mkdtemp(prefix="nux_cls_")
        with tarfile.open(fp, "r:*") as tar: tar.extractall(td)
        with open(os.path.join(td,"metadata.json"),"w") as f:
            json.dump(meta, f, indent=2, ensure_ascii=False)
        tmp = fp + ".tmp"
        with tarfile.open(tmp, "w:xz") as tar:
            for n in names:
                p = os.path.join(td, n)
                if os.path.exists(p) or os.path.islink(p):
                    tar.add(p, arcname=n)
        os.replace(tmp, fp)
        shutil.rmtree(td, ignore_errors=True)
        c = CC.get(new,"")
        o = old if old else "none"
        print(f"  [{i}/{len(files)}] {name:<35} {o:>6} → {c}{new}{RS}")
        updated += 1
    except Exception as e:
        print(f"  [{i}/{len(files)}] {fn}: ERROR: {e}")
        errors += 1

print(f"\n  Updated: {updated} | Skipped: {skipped} | Errors: {errors}")
PYCLASS

    rm -f "$CACHE_DB"
    printf '{}' > "$CACHE_DB"
    index_rebuild
}

