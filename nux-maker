# DEBIAN APT SANDBOX
# ══════════════════════════════════════════════════════════════════

init_debian_sandbox() {
    mkdir -p \
        "$APT_ETC/preferences.d" \
        "$APT_ETC/apt.conf.d" \
        "$APT_ETC/trusted.gpg.d" \
        "$APT_VAR/lists/partial" \
        "$APT_CACHE_DIR/partial" \
        "$APT_DPKG"

    [ -f "$APT_STATUS" ] || : > "$APT_STATUS"

    cat > "$APT_ETC/sources.list" <<SRCEOF
deb [arch=$TARGET_ARCH signed-by=/usr/share/keyrings/debian-archive-keyring.gpg] $TARGET_MIRROR $TARGET_SUITE main contrib non-free non-free-firmware
deb [arch=$TARGET_ARCH signed-by=/usr/share/keyrings/debian-archive-keyring.gpg] $TARGET_MIRROR ${TARGET_SUITE}-updates main contrib non-free non-free-firmware
deb [arch=$TARGET_ARCH signed-by=/usr/share/keyrings/debian-archive-keyring.gpg] $TARGET_SECURITY ${TARGET_SUITE}-security main contrib non-free non-free-firmware
SRCEOF

    if [ ! -f /usr/share/keyrings/debian-archive-keyring.gpg ]; then
        apt-get install -y -qq debian-archive-keyring >/dev/null 2>&1 || true
    fi
}

get_apt_opts() {
    echo \
        -o "Dir=$APT_SANDBOX" \
        -o "Dir::Etc=$APT_ETC" \
        -o "Dir::Etc::sourcelist=$APT_ETC/sources.list" \
        -o "Dir::Etc::sourceparts=-" \
        -o "Dir::State=$APT_VAR" \
        -o "Dir::State::status=$APT_STATUS" \
        -o "Dir::Cache=$APT_SANDBOX/var/cache/apt" \
        -o "Dir::Cache::archives=$APT_CACHE_DIR" \
        -o "APT::Architecture=$TARGET_ARCH" \
        -o "Acquire::Languages=none"
}

SANDBOX_UPDATED=0

debian_update() {
    [ "$SANDBOX_UPDATED" -eq 1 ] && return 0
    init_debian_sandbox
    echo -e "${C}Debian $TARGET_SUITE repo index...${RE}"
    local opts
    opts="$(get_apt_opts)"
    apt-get $opts update -qq >/dev/null 2>&1 || {
        echo -e "${R}Debian repo update failed${RE}" >&2
        return 1
    }
    SANDBOX_UPDATED=1
    echo -e "${G}Debian $TARGET_SUITE ready${RE}"
}

debian_pkg_exists() {
    local opts
    opts="$(get_apt_opts)"
    apt-cache $opts show "$1" >/dev/null 2>&1
}

debian_download() {
    local pkg="$1" outdir="$2"
    local opts
    opts="$(get_apt_opts)"
    (cd "$outdir" && apt-get $opts download "$pkg" >/dev/null 2>&1)
}

debian_depends_recursive() {
    local pkg="$1"
    local opts
    opts="$(get_apt_opts)"
    apt-cache $opts depends --recurse \
        --no-recommends --no-suggests --no-conflicts \
        --no-breaks --no-replaces --no-enhances \
        "$pkg" 2>/dev/null \
    | sed -n 's/.*Depends: //p; s/.*PreDepends: //p' \
    | sed 's/<//g; s/>//g' \
    | grep -v "^${pkg}$" \
    | sort -u || true
}

