    local key="$1"
    if [ "$LANG_CURRENT" = "tr" ]; then
        echo "${I18N_TR[$key]:-$key}"
    else
        echo "${I18N_EN[$key]:-$key}"
    fi
}

# ══════════════════════════════════════════════════════════════════
# CONFIG OKUYUCU
# ══════════════════════════════════════════════════════════════════

cfg() {
    local key="$1"
    local default="${2:-}"
    if [ -f "$CONFIG_FILE" ]; then
        python3 -c "
import json
d = json.load(open('$CONFIG_FILE'))
keys = '$key'.split('.')
for k in keys:
    if isinstance(d, dict):
        d = d.get(k, '')
    else:
        d = ''
        break
print(d if d else '$default')
" 2>/dev/null || echo "$default"
    else
        echo "$default"
    fi
}

# Config varsa değerleri yükle
if [ -f "$CONFIG_FILE" ]; then
    REPO_ROOT="$(cfg repo.root "$DEFAULT_REPO_ROOT")"
    PACKAGES_DIR="$(cfg repo.packages_dir "$REPO_ROOT/packages")"
    CACHE_DIR="$(cfg repo.cache_dir "$REPO_ROOT/.cache")"
    LOG_DIR="$(cfg repo.log_dir "$REPO_ROOT/.logs")"
    CACHE_DB="$CACHE_DIR/metadata_cache.json"
    TARGET_SUITE="$(cfg debian.suite "trixie")"
    TARGET_ARCH="$(cfg debian.arch "amd64")"
    TARGET_MIRROR="$(cfg debian.mirror "http://deb.debian.org/debian")"
    TARGET_SECURITY="$(cfg debian.security "http://security.debian.org/debian-security")"
else
    REPO_ROOT="$DEFAULT_REPO_ROOT"
    PACKAGES_DIR="$REPO_ROOT/packages"
    CACHE_DIR="$REPO_ROOT/.cache"
    LOG_DIR="$REPO_ROOT/.logs"
    CACHE_DB="$CACHE_DIR/metadata_cache.json"
    TARGET_SUITE="trixie"
    TARGET_ARCH="amd64"
    TARGET_MIRROR="http://deb.debian.org/debian"
    TARGET_SECURITY="http://security.debian.org/debian-security"
fi

