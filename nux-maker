index_rebuild() {
    echo -e "${C}$(t index.rebuilding)${RE}"

    python3 - "$PACKAGES_DIR" "$REPO_ROOT/index.json" "$CACHE_DIR/metadata_cache.json" "$MAKER_VERSION" <<'PYINDEX'
import json, os, sys, tarfile, time, hashlib
from datetime import datetime

packages_dir = sys.argv[1]
index_file   = sys.argv[2]
cache_file   = sys.argv[3]
maker_ver    = sys.argv[4]

cache = {}
if os.path.exists(cache_file):
    try:
        with open(cache_file) as f:
            cache = json.load(f)
    except Exception:
        cache = {}

files = sorted(f for f in os.listdir(packages_dir) if f.endswith(".nux"))

new_cache = {}
packages = {}
total_versions = 0
cache_hits = cache_misses = errors = 0

for fn in files:
    path = os.path.join(packages_dir, fn)
    try:
        st = os.stat(path)
    except OSError:
        errors += 1
        continue

    cache_key = f"{fn}:{st.st_size}:{int(st.st_mtime)}"

    if fn in cache and cache[fn].get("_cache_key") == cache_key:
        meta = cache[fn]
        cache_hits += 1
    else:
        try:
            with tarfile.open(path, "r:*") as tar:
                m = tar.getmember("metadata.json")
                fo = tar.extractfile(m)
                meta = json.load(fo) if fo else {}
        except Exception:
            errors += 1
            continue
        meta["_cache_key"] = cache_key
        meta["_filename"] = fn
        meta["_file_size"] = st.st_size
        cache_misses += 1

    new_cache[fn] = meta

    name = meta.get("name", "")
    version = meta.get("version", "")
    if not name or not version:
        continue

    # sha256
    sha = hashlib.sha256()
    with open(path, "rb") as f:
        for chunk in iter(lambda: f.read(1048576), b""):
            sha.update(chunk)

    ver_info = {k: v for k, v in meta.items() if not k.startswith("_")}
    ver_info["filename"] = f"packages/{fn}"
    ver_info["sha256"] = sha.hexdigest()
    ver_info["size"] = st.st_size

    if name not in packages:
        packages[name] = {"latest": version, "versions": {}}
    packages[name]["versions"][version] = ver_info
    packages[name]["latest"] = version
    total_versions += 1

# Cache kaydet
try:
    with open(cache_file, "w") as f:
        json.dump(new_cache, f, separators=(",", ":"), ensure_ascii=False)
except Exception:
    pass

# Index oluştur
index = {
    "generated_at": datetime.utcnow().isoformat() + "Z",
    "generator": f"nux-maker/{maker_ver}",
    "package_count": len(packages),
    "version_count": total_versions,
    "packages": packages,
}

with open(index_file, "w", encoding="utf-8") as f:
    json.dump(index, f, indent=2, ensure_ascii=False)

print(f"[OK] index.json — {len(packages)} packages, {total_versions} versions")
print(f"[OK] Cache: {cache_hits} hit, {cache_misses} miss, {errors} errors")
PYINDEX
}

